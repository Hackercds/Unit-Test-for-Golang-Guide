#!/bin/sh
# Pre-commit hook: run vet and tests before allowing commit
# To enable: git config core.hooksPath .githooks
# To skip:   git commit --no-verify

echo "=== Running go vet ==="
go vet ./...
if [ $? -ne 0 ]; then
    echo "FAIL: go vet found issues. Fix them before committing."
    exit 1
fi

echo "=== Running tests ==="
go test ./...
if [ $? -ne 0 ]; then
    echo "FAIL: Tests must pass before committing."
    exit 1
fi

echo "=== All checks passed ==="
